# Öffentliche Basis-URL (ohne abschließenden Slash)
NEXT_PUBLIC_SITE_URL=https://www.schulung-wimpernverlaengerung.de

# PostgreSQL / Supabase (Projekt möglichst in EU-Region anlegen)
# DATABASE_URL wird von CLI-/Migrationswerkzeugen genutzt, nicht vom App-Prozess.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY

# Stripe – genau ein Produkt und ein aktiver Einmalpreis
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRODUCT_ID=prod_REPLACE_ME
STRIPE_PRICE_ID=price_REPLACE_ME
# true aktiviert Stripe Automatic Tax; vorher Steuerkonfiguration im Dashboard prüfen
STRIPE_AUTOMATIC_TAX=false
# Beide Freigaben müssen vor einem Verkauf ausdrücklich gesetzt werden.
CONTENT_RELEASE_APPROVED=false
LEGAL_TEXTS_APPROVED=false
CHECKOUT_CONSENT_VERSION=checkout-2026-07-21
# Nicht geheim: SHA-256-Fingerabdruck der freigegebenen Rechtstexte.
# Erst nach finaler Textprüfung mit `npm run legal:hash` erzeugen und den
# Platzhalter durch die unveränderte Ausgabe ersetzen.
CHECKOUT_LEGAL_TEXT_HASH=sha256_REPLACE_WITH_APPROVED_TEXT_HASH
# Ausschließlich serverseitig: bindet den anonymen Checkout an denselben Browser.
# Erzeuge mindestens 32 zufällige Zeichen, z. B. mit `openssl rand -base64 48`.
CHECKOUT_INTENT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
# Zeit für Dateneingabe/E-Mail-Bestätigung. Beim Öffnen der Stripe-Sitzung wird
# die sichere Browserbindung zusätzlich bis Stripe-Ablauf plus Nachlauf verlängert.
CHECKOUT_INTENT_TTL_SECONDS=3600
MARKETING_CONSENT_VERSION=marketing-2026-07-21
# Jede inhaltliche Änderung am Banner erhöht diese Version und fragt erneut.
NEXT_PUBLIC_COOKIE_CONSENT_VERSION=cookies-2026-07-21

# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# Von Cloudflare geliefertes Base64-JWK/-PEM (oder dekodierter Private Key) plus Key-ID
CLOUDFLARE_STREAM_SIGNING_KEY=YOUR_PRIVATE_SIGNING_KEY
CLOUDFLARE_STREAM_SIGNING_KEY_ID=YOUR_SIGNING_KEY_ID
# Nur den Wert zwischen `customer-` und `.cloudflarestream.com` eintragen.
CLOUDFLARE_STREAM_CUSTOMER_CODE=YOUR_CUSTOMER_CODE
VIDEO_TOKEN_TTL_SECONDS=5400

# Transaktionale E-Mail (Resend-kompatibel)
EMAIL_PROVIDER_API_KEY=re_REPLACE_ME
EMAIL_FROM=Schulung Wimpernverlängerung <support@example.de>
SUPPORT_EMAIL=support@example.de
# Mindestens 32 zufällige Zeichen; Vercel Cron sendet den Wert als Bearer-Token.
CRON_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

# Zertifikat
CERTIFICATE_ISSUER_NAME=RECHTLICHER_UNTERNEHMENSNAME
CERTIFICATE_SIGNATORY_NAME=Lea Kirfel
CERTIFICATE_SIGNATURE_FILE=/absolute/path/to/approved-signature.png
CERTIFICATE_STORAGE_BUCKET=certificates
COURSE_MATERIALS_BUCKET=course-materials
CERTIFICATE_VERIFICATION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

# Administration
# Nur Empfänger für Zahlungs-/Dispute-Warnungen. Diese Liste verleiht niemals
# Adminrechte; diese werden ausschließlich per user_roles und fester Auth-UID vergeben.
ADMIN_EMAILS=admin@example.de
SESSION_FINGERPRINT_SECRET=replace-with-a-long-random-secret
# Nur nach verifiziertem Ingress-Vertrag setzen: `vercel` oder `cloudflare`.
# Leer = sicherer gemeinsamer Anonymous-Bucket; keine Client-IP-Header werden vertraut.
TRUSTED_CLIENT_IP_SOURCE=

# Anbieterangaben – vor Veröffentlichung vollständig pflegen
NEXT_PUBLIC_LEGAL_COMPANY_NAME=
NEXT_PUBLIC_LEGAL_REPRESENTATIVE=Lea Kirfel
NEXT_PUBLIC_LEGAL_STREET=
NEXT_PUBLIC_LEGAL_POSTAL_CITY=
NEXT_PUBLIC_LEGAL_COUNTRY=Deutschland
NEXT_PUBLIC_LEGAL_EMAIL=
NEXT_PUBLIC_LEGAL_PHONE=
NEXT_PUBLIC_LEGAL_VAT_ID=
# Explizit `assigned` oder `not_assigned`; bei `assigned` ist die W-IdNr Pflicht.
NEXT_PUBLIC_LEGAL_WID_STATUS=
NEXT_PUBLIC_LEGAL_WID_ID=
# Explizit `registered` oder `not_registered`; bei `registered` sind die
# beiden folgenden Registerangaben Pflicht.
NEXT_PUBLIC_LEGAL_REGISTER_STATUS=
NEXT_PUBLIC_LEGAL_REGISTER_COURT=
NEXT_PUBLIC_LEGAL_REGISTER_NUMBER=
# Rechtlich geprüfte Erklärung nach § 36 VSBG, zum Beispiel ob eine Teilnahme
# an Verbraucherstreitbeilegung besteht. Keine Entscheidung ungeprüft übernehmen.
NEXT_PUBLIC_LEGAL_DISPUTE_STATEMENT=
